{
  "name": "@qijenchen/product-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "echo 'pick an app:npm -w @qijenchen/<app-name> run dev'",
    "build": "npm run build --workspaces --if-present",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static",
    "create-app": "node scripts/create-app.mjs",
    "audit:tsc": "npx tsc -b",
    "audit:content": "node node_modules/@qijenchen/design-system/scripts/audit-content-quality.mjs --check",
    "audit:code": "node node_modules/@qijenchen/design-system/scripts/code-quality-audit.mjs --scope=apps",
    "audit:all": "npm run audit:tsc && npm run audit:content && npm run audit:code"
  },
  "dependencies": {
    "@qijenchen/design-system": "^0.1.0",
    "@qijenchen/storybook-config": "^0.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@tailwindcss/vite": "^4.2.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "storybook": "8.6.0",
    "@storybook/react": "8.6.0",
    "@storybook/react-vite": "8.6.0"
  }
}
